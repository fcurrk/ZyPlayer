{
  "name": "@zy/crypto",
  "version": "0.1.0",
  "type": "module",
  "description": "zy crypto bundle",
  "keywords": [
    "zy",
    "crypto"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.dts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsc -w",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "fflate": "^0.8.2",
    "he": "^1.2.0",
    "node-forge": "^1.4.0",
    "sm-crypto-v2": "^1.15.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/he": "^1",
    "@types/node-forge": "^1.3.14",
    "rimraf": "^6.1.3",
    "tsdown": "^0.20.3",
    "typescript": "^5.8.3"
  }
}
